# ── HIT TEST ──────────────────────────────────────────────────────────────────
def hit_test(app, mx, my, W, H):
    # Sidebar
    nav_keys=["home","algebra1","geometry","algebra2","english"]
    for i,key in enumerate(nav_keys):
        ry=70+i*50
        if 4<=mx<=SIDEBAR_W-4 and ry<=my<=ry+42: return ("nav",key)
    mix_y=70+len(nav_keys)*50+6
    if 4<=mx<=SIDEBAR_W-4 and mix_y<=my<=mix_y+42: return ("nav","mixed")
    if mx<SIDEBAR_W: return None

    VX=SIDEBAR_W+14; VW=W-VX-14; VH=H-58
    lx=mx-VX; ly=my-58+int(app.scroll.y)

    if app.screen=="home":
        PAD=14; CW=(VW-44-PAD)//2; CH=192
        row_y=24+52+40
        for i,key in enumerate(QUESTIONS):
            col_=i%2; row_=i//2
            cx=22+col_*(CW+PAD); cy=row_y+row_*(CH+PAD)
            if cx<=lx<=cx+CW and cy<=ly<=cy+CH: return ("card",key)
        rows=(len(QUESTIONS)+1)//2
        y_mix=row_y+rows*(CH+PAD)+24+38+106+36+len(QUESTIONS)*62+8
        # mixed CTA: simpler estimate
        y_mix_est=row_y+rows*(CH+PAD)+24+38+106+36+4*62+8
        if 22<=lx<=VW-22 and y_mix_est<=ly<=y_mix_est+84: return ("mixed_cta",None)

    elif app.screen=="topic":
        y0=20+140+34
        btns=[("q5",0),("q10",1),("q20",2),("q40",3)]
        for bk,j in btns:
            if 0<=lx<=210 and y0+j*56<=ly<=y0+j*56+44: return ("tbtn",bk)

    elif app.screen=="quiz" and app.qs:
        q=app.qs[app.qi]; CX2=SIDEBAR_W+22; QW=W-SIDEBAR_W-44
        lines=[]
        for line in q["q"].split("\n"):
            lines+=textwrap.wrap(line,max(20,int(QW*0.9/7))) or [""]
        QH=max(110,60+len(lines)*24)
        base_y=70+QH+12; CH2=52
        for i in range(4):
            ay=base_y+i*(CH2+8)
            if CX2<=mx<=CX2+QW and ay<=my<=ay+CH2: return ("choice",i)
        after=base_y+4*(CH2+8)
        if app.revealed:
            exp=q.get("exp","")
            wls=textwrap.wrap(exp,max(20,int(QW*0.9/7.5)))
            after+=6+14+len(wls)*22+14+10
        by=after+6
        if not app.revealed:
            if CX2<=mx<=CX2+180 and by<=my<=by+44: return ("btn","hint")
            if CX2+QW-218<=mx<=CX2+QW and by<=my<=by+44: return ("btn","submit")
        else:
            if CX2+QW-238<=mx<=CX2+QW and by<=my<=by+44: return ("btn","next")

    elif app.screen=="results":
        topic_set=len(set(t for t,_,_ in app.history))
        y_pa_est=196+46+104+34+topic_set*68+8+34+len(app.history)*64+18
        if 22<=lx<=VW-22 and y_pa_est<=ly<=y_pa_est+56: return ("btn","play_again")

    return None

# ── MAIN ──────────────────────────────────────────────────────────────────────
def main():
    global screen, particles
    app=App()
    running=True
    while running:
        W,H=screen.get_size()
        clock.tick(60)
        mx,my=pygame.mouse.get_pos()
        app.hover=hit_test(app,mx,my,W,H)
        app.update_anims()

        for ev in pygame.event.get():
            if ev.type==pygame.QUIT: running=False; break
            if ev.type==pygame.VIDEORESIZE:
                screen=pygame.display.set_mode((ev.w,ev.h),pygame.RESIZABLE)
            if ev.type==pygame.MOUSEWHEEL and app.screen!="quiz":
                app.scroll.scroll(ev.y,H-58)
            if ev.type==pygame.MOUSEBUTTONDOWN and ev.button==1:
                h=app.hover
                if not h: continue
                k,v=h
                if k=="nav":
                    if v=="mixed": app.start_mixed(10)
                    elif v=="home": app.go("home")
                    else: app.go("topic",topic=v)
                elif k=="card": app.go("topic",topic=v)
                elif k=="mixed_cta": app.start_mixed(10)
                elif k=="tbtn":
                    n_map={"q5":5,"q10":10,"q20":20,"q40":40}
                    app.start_quiz(app.topic,n_map[v])
                elif k=="choice":
                    if not app.revealed: app.sel=v
                elif k=="btn":
                    if v=="submit": app.submit()
                    elif v=="next":
                        was_ok=app.history[-1][1] if app.history else False
                        app.next_q()
                        if app.screen=="quiz":
                            burst(W//2,H//2,GREEN_C if was_ok else RED_C)
                    elif v=="hint": app.use_hint()
                    elif v=="play_again": app.go("home")

        # ── RENDER ────────────────────────────────────────────────────
        screen.fill(BG)
        # grid
        gs=pygame.Surface((W,H),pygame.SRCALPHA)
        for gx in range(SIDEBAR_W,W,60):
            pygame.draw.line(gs,(255,255,255,4),(gx,58),(gx,H))
        for gy in range(58,H,60):
            pygame.draw.line(gs,(255,255,255,4),(SIDEBAR_W,gy),(W,gy))
        screen.blit(gs,(0,0))

        draw_sidebar(app,W,H)
        draw_topbar(app,W,H)

        if   app.screen=="home":    draw_home(app,W,H)
        elif app.screen=="topic":   draw_topic(app,W,H)
        elif app.screen=="quiz":    draw_quiz(app,W,H)
        elif app.screen=="results": draw_results(app,W,H)

        # clip sidebar/topbar overlap
        draw_rect(screen,SIDE_BG,(0,0,SIDEBAR_W,H))
        pygame.draw.line(screen,BORDER,(SIDEBAR_W,0),(SIDEBAR_W,H),1)
        draw_sidebar(app,W,H)
        draw_rect(screen,SIDE_BG,(0,0,W,58))
        pygame.draw.line(screen,BORDER,(0,58),(W,58),1)
        draw_topbar(app,W,H)

        # particles
        particles=[p for p in particles if p.update()]
        for p in particles: p.draw(screen)

        pygame.mouse.set_cursor(
            pygame.SYSTEM_CURSOR_HAND if app.hover else pygame.SYSTEM_CURSOR_ARROW)
        pygame.display.flip()

    pygame.quit(); sys.exit()

if __name__=="__main__":
    main()
