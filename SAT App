# ── HELPERS ───────────────────────────────────────────────────────────────────
def draw_rect(surf, color, r, radius=0):
    pygame.draw.rect(surf, color, r, border_radius=int(radius))

def draw_rect_border(surf, color, r, radius=0, w=1):
    pygame.draw.rect(surf, color, r, int(w), border_radius=int(radius))

def draw_text(surf, text, fnt, color, x, y, anchor="topleft", max_w=None):
    if max_w:
        words = text.split(" ")
        lines, cur = [], []
        for word in words:
            test = " ".join(cur + [word])
            if fnt.size(test)[0] <= max_w:
                cur.append(word)
            else:
                if cur: lines.append(" ".join(cur))
                cur = [word]
        if cur: lines.append(" ".join(cur))
        lh = fnt.get_linesize() + 2
        for i, line in enumerate(lines):
            draw_text(surf, line, fnt, color, x, y + i*lh, anchor)
        return len(lines) * lh
    s = fnt.render(text, True, color)
    r2 = s.get_rect(**{anchor: (x, y)})
    surf.blit(s, r2)
    return fnt.get_height()

def pill(surf, bg_c, border_c, x, y, w, h, label, fnt, tc):
    draw_rect(surf, bg_c, (x,y,w,h), h//2)
    draw_rect_border(surf, border_c, (x,y,w,h), h//2, 1)
    draw_text(surf, label, fnt, tc, x+w//2, y+h//2, "center")

def pbar(surf, x, y, w, h, pct, bg=BORDER, fg=ACCENT, radius=4):
    draw_rect(surf, bg, (x,y,w,h), radius)
    if pct > 0:
        fw = max(int(radius)*2, int(w*pct))
        draw_rect(surf, fg, (x,y,fw,h), radius)

def lerp(a, b, t):
    return a + (b-a)*t

def clamp(v,lo,hi):
    return max(lo,min(hi,v))

# ── SCROLL ────────────────────────────────────────────────────────────────────
class Scroll:
    def __init__(self):
        self.y = 0.0          # current scroll position (pixels)
        self.target = 0.0     # smooth scroll target
        self.content_h = 0

    def reset(self):
        self.y = 0.0; self.target = 0.0

    def scroll(self, dy, view_h):
        max_s = max(0, self.content_h - view_h)
        self.target = clamp(self.target - dy*36, 0, max_s)

    def update(self):
        self.y = lerp(self.y, self.target, 0.18)

    def draw_bar(self, screen, view_x, view_y, view_w, view_h):
        if self.content_h <= view_h: return
        track_h = view_h - 8
        sb_h  = max(32, int(track_h * view_h / self.content_h))
        ratio = self.y / max(1, self.content_h - view_h)
        sb_y  = 4 + int(ratio * (track_h - sb_h))
        # track
        draw_rect(screen, (30,36,48), (view_x+view_w-8, view_y+4, 5, track_h), 3)
        # thumb
        draw_rect(screen, SCROLLBAR, (view_x+view_w-8, view_y+sb_y, 5, sb_h), 3)

# ── PARTICLES ──────────────────────────────────────────────────────────────────
class Particle:
    def __init__(self, x, y, color):
        self.x=float(x); self.y=float(y)
        self.vx=random.uniform(-5,5); self.vy=random.uniform(-10,-2)
        self.color=color; self.life=1.0; self.r=random.randint(3,8)
    def update(self):
        self.x+=self.vx; self.y+=self.vy; self.vy+=0.3
        self.life-=0.03; return self.life>0
    def draw(self, surf):
        a=int(self.life*255)
        s=pygame.Surface((self.r*2,self.r*2),pygame.SRCALPHA)
        pygame.draw.circle(s,(*self.color,a),(self.r,self.r),self.r)
        surf.blit(s,(int(self.x)-self.r,int(self.y)-self.r))

particles: list = []
def burst(x, y, color, n=22):
    for _ in range(n): particles.append(Particle(x,y,color))

# ── ANIMATED COUNTERS ─────────────────────────────────────────────────────────
class Counter:
    def __init__(self): self.display=0.0; self.target=0
    def set(self, v): self.target=v
    def update(self): self.display=lerp(self.display,self.target,0.12)
    def val(self): return int(self.display)

# ── STATE ─────────────────────────────────────────────────────────────────────
class App:
    def __init__(self):
        self.screen   = "home"
        self.topic    = None
        self.qs       = []
        self.qi       = 0
        self.sel      = None
        self.revealed = False
        self.hint_used= False
        self.hint_elim= None
        self.score    = 0
        self.total    = 0
        self.history  = []
        self.streak   = 0
        self.best_str = 0
        self.t0       = time.time()
        self.slide    = 0.0
        self.flash_ok = 0.0
        self.flash_no = 0.0
        self.topic_stats = {k:{"c":0,"t":0} for k in QUESTIONS}
        self.scroll   = Scroll()
        self.hover    = None
        # Dashboard animations
        self.dash_anim   = 0.0   # 0→1 on enter
        self.card_hover_t= {k:0.0 for k in QUESTIONS}  # per-card hover glow
        self.counters    = {
            "answered": Counter(),
            "correct":  Counter(),
            "streak":   Counter(),
            "accuracy": Counter(),
        }
        # Pulse animation t
        self.pulse_t = 0.0

    def go(self, s, **kw):
        prev = self.screen
        self.screen = s
        self.scroll.reset()
        for k,v in kw.items(): setattr(self,k,v)
        if s=="home": self.dash_anim=0.0

    def start_quiz(self, key, n):
        pool = QUESTIONS[key][:]
        random.shuffle(pool)
        self.qs = pool[:n]
        self._reset_quiz(key)

    def start_mixed(self, n):
        pool=[]
        for k,qs in QUESTIONS.items():
            s=qs[:]; random.shuffle(s)
            pool+=[{"_t":k,**q} for q in s[:max(1,n//4)]]
        random.shuffle(pool); self.qs=pool[:n]
        self._reset_quiz("mixed")

    def _reset_quiz(self, key):
        self.topic=key; self.qi=0; self.sel=None
        self.revealed=False; self.hint_used=False; self.hint_elim=None
        self.score=0; self.total=0; self.history=[]
        self.streak=0; self.t0=time.time(); self.slide=1.0
        self.go("quiz")

    def submit(self):
        if self.sel is None or self.revealed: return
        self.revealed=True
        q=self.qs[self.qi]; t=q.get("_t",self.topic)
        ok=self.sel==q["ans"]
        self.total+=1; self.topic_stats[t]["t"]+=1
        self.history.append((t,ok,q))
        if ok:
            self.score+=1; self.topic_stats[t]["c"]+=1
            self.streak+=1; self.best_str=max(self.best_str,self.streak)
            self.flash_ok=1.0
        else:
            self.streak=0; self.flash_no=1.0

    def next_q(self):
        self.qi+=1; self.sel=None; self.revealed=False
        self.hint_used=False; self.hint_elim=None; self.slide=1.0
        if self.qi>=len(self.qs): self.go("results")

    def use_hint(self):
        if self.hint_used or self.revealed: return
        q=self.qs[self.qi]
        wrong=[i for i in range(4) if i!=q["ans"]]
        self.hint_elim=random.choice(wrong); self.hint_used=True

    def elapsed(self):
        s=int(time.time()-self.t0); m,s2=divmod(s,60)
        return f"{m:02d}:{s2:02d}"

    def update_anims(self):
        self.pulse_t += 0.04
        if self.screen=="home":
            self.dash_anim = min(1.0, self.dash_anim+0.04)
            for k in QUESTIONS:
                target = 1.0 if self.hover==("card",k) else 0.0
                self.card_hover_t[k] = lerp(self.card_hover_t[k], target, 0.15)
        # Update counters
        tc=sum(v["t"] for v in self.topic_stats.values())
        cc=sum(v["c"] for v in self.topic_stats.values())
        acc=int(cc/tc*100) if tc else 0
        self.counters["answered"].set(tc)
        self.counters["correct"].set(cc)
        self.counters["streak"].set(self.best_str)
        self.counters["accuracy"].set(acc)
        for c in self.counters.values(): c.update()
        self.scroll.update()

